CONFIG=/home/dev-admin/.jitsi-meet-cfg

HTTP_PORT=80
HTTPS_PORT=443
DISABLE_HTTPS=0
ENABLE_HTTP_REDIRECT=1

PUBLIC_URL= <https://your-domain.com>
TZ=Asia/Karachi

XMPP_SERVER=xmpp.meet.jitsi
XMPP_PORT=5222


XMPP_DOMAIN=meet.jitsi
XMPP_AUTH_DOMAIN=auth.meet.jitsi
XMPP_INTERNAL_MUC_DOMAIN=internal-muc.meet.jitsi
XMPP_MUC_DOMAIN=muc.meet.jitsi
XMPP_RECORDER_DOMAIN=recorder.meet.jitsi
XMPP_HIDDEN_DOMAIN=recorder.meet.jitsi

ENABLE_XMPP_WEBSOCKET=1
ENABLE_COLIBRI_WEBSOCKET=1

JVB_PORT=10000
JVB_ADVERTISE_IPS=YOUR_PRIVATE_IP,YOUR_PUBLIC_IP
DOCKER_HOST_ADDRESS=YOUR_PRIVATE_IP
JVB_ADVERTISE_PRIVATE_CANDIDATES=1
JVB_WS_DOMAIN= <your-domain.com>
JVB_WS_TLS=1

JICOFO_AUTH_USER=focus
JVB_AUTH_USER=jvb

ENABLE_LETSENCRYPT=0

ENABLE_RECORDING=1
ENABLE_FILE_RECORDING_SERVICE=1
ENABLE_LIVESTREAMING=1
ENABLE_SERVICE_RECORDING=1

RESTART_POLICY=unless-stopped
JITSI_IMAGE_VERSION=stable



# Security
# Keep your generated passwords exactly as they are
#
# XMPP password for Jicofo client connections
JICOFO_AUTH_PASSWORD= <CHANGE_ME>
# XMPP password for JVB client connections
JVB_AUTH_PASSWORD= <CHANGE_ME>
# XMPP password for Jigasi MUC client connections
JIGASI_XMPP_PASSWORD= <CHANGE_ME>
# XMPP password for Jigasi transcriber client connections
JIGASI_TRANSCRIBER_PASSWORD= <CHANGE_ME>
# XMPP recorder password for Jibri client connections
JIBRI_RECORDER_PASSWORD= <CHANGE_ME>
# XMPP password for Jibri client connections
JIBRI_XMPP_PASSWORD= <CHANGE_ME>






# Jibri settings
# Add these explicitly
#
JIBRI_RECORDER_USER=recorder
JIBRI_XMPP_USER=jibri
JIBRI_BREWERY_MUC=jibribrewery
JIBRI_STRIP_DOMAIN_JID=muc
JIBRI_PENDING_TIMEOUT=90
JIBRI_RECORDING_DIR=/config/recordings
JIBRI_LOGS_DIR=/config/logs

ENABLE_TURN_CREDENTIALS=1
